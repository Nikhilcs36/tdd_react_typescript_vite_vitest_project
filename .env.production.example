# ============================================
# Frontend Production Environment Variables
# ============================================
# Copy this file to .env.production and fill in your values.
# .env.production is gitignored (contains secrets).
#
# Usage:
#   cp .env.production.example .env.production
#   # Then edit .env.production with real values (if needed)
# ============================================

# API Proxy Target
# Used ONLY by Vite dev server for local development.
# In production (Docker build + Nginx), this is NOT used
# because the built React app uses relative paths (/api/*)
# and the EC2 Nginx handles routing.
VITE_API_PROXY_TARGET=http://backend:8000